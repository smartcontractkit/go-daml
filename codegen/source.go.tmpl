// MCMSEncoder interface for typed encoding methods.
// Implemented by Encoder for method-based encoding.
type MCMSEncoder interface {
{{- range $structs4}}
{{- $goName := capitalise .Name}}
{{- $damlName := damlName .}}
{{- $isChoiceArgType := index $choiceArgTypes $goName}}
{{- $isParamsType := stringsHasSuffix $damlName "Params"}}
{{- $baseNameForParams := stringsTrimSuffix $damlName "Params"}}
{{- $hasParamEncoder := and $isParamsType (index $paramEncoderNames $baseNameForParams)}}
{{- if and (not .IsInterface) (not .IsTemplate) (eq .RawType "Record") (or $isChoiceArgType $hasParamEncoder)}}
{{- /* Generate encoder for all choice types and *Params types */}}
{{- $methodName := index $encoderMethodNames $goName}}
{{- if eq $methodName ""}}{{$methodName = $goName}}{{end}}
	{{$methodName}}(args {{$goName}}) (*bind.EncodedChoice, error)
{{- if and $isChoiceArgType (hasCallerField .)}}
	{{$methodName}}MCMSParams(args {{$goName}}MCMSParams) (*bind.EncodedChoice, error)
